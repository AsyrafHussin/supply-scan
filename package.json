  "repository": {
    "type": "git",
    "url": "git+https://github.com/AsyrafHussin/supply-scan.git"
  },
  "bugs": {
    "url": "https://github.com/AsyrafHussin/supply-scan/issues"
  },
  "homepage": "https://github.com/AsyrafHussin/supply-scan#readme",
  "type": "module",
  "bin": {
